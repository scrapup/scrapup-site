---
import { useTranslations, type Lang } from '../../i18n';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const pillars = [
  { n: 'P1', title: 'pillars.p1.title', desc: 'pillars.p1.desc' },
  { n: 'P2', title: 'pillars.p2.title', desc: 'pillars.p2.desc' },
  { n: 'P3', title: 'pillars.p3.title', desc: 'pillars.p3.desc' },
  { n: 'P4', title: 'pillars.p4.title', desc: 'pillars.p4.desc' },
] as const;
---

<div class="pillars">
  <div class="kicker pillars__kicker">
    <span>{t('pillars.label')}</span>
  </div>
  <h2 class="section-title pillars__title">
    {t('pillars.title')}
  </h2>
  <div class="pillars__grid">
    {
      pillars.map((p) => (
        <div class="card">
          <div class="pillars__code">{p.n}</div>
          <div class="item-title pillars__item-title">{t(p.title)}</div>
          <div class="item-desc pillars__item-desc">{t(p.desc)}</div>
        </div>
      ))
    }
  </div>
</div>

<style>
  .pillars {
    margin-top: 108px;
  }

  .pillars__kicker {
    letter-spacing: 0.2em;
    color: var(--cy);
    margin-bottom: 16px;
  }

  .pillars__title {
    margin: 0 0 30px;
  }

  .pillars__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(248px, 1fr));
    gap: 18px;
  }

  .pillars__code {
    font-family: 'IBM Plex Mono', 'Noto Sans JP', monospace;
    font-size: 12px;
    color: var(--neon);
    text-shadow: 0 0 10px color-mix(in srgb, var(--neon) 50%, transparent);
  }

  .pillars__item-title {
    font-size: 1.05rem;
    line-height: 1.25;
    margin-top: 10px;
  }

  .pillars__item-desc {
    margin-top: 9px;
  }
</style>
