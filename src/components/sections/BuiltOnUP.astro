---
import { useTranslations, type Lang } from '../../i18n';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const tag =
  "font-family:'IBM Plex Mono','Noto Sans JP',monospace; font-size:12px; color:#C7CCD8; background:rgba(53,230,224,.07); border:1px solid rgba(53,230,224,.2); padding:7px 13px;";
const pillars = [
  'use-case driven',
  'architecture-centric',
  'iterative & incremental',
  'risk-driven',
];
---

<div style="margin-top:108px;">
  <div
    style="font-family:'IBM Plex Mono','Noto Sans JP',monospace; font-size:11px; letter-spacing:.2em; color:var(--cy); margin-bottom:16px;"
  >
    <span>{t('up.label')}</span>
  </div>
  <h2
    style="margin:0 0 14px; max-width:20ch; font-family:'Space Grotesk','Noto Sans JP',sans-serif; font-weight:600; font-size:clamp(1.7rem,3.2vw,2.6rem); line-height:1.08; letter-spacing:-.02em; color:#F2F3F8;"
  >
    {t('up.title')}
  </h2>
  <p style="margin:0 0 24px; max-width:640px; font-size:1.05rem; line-height:1.6; color:#AEB4C2;">
    {t('up.body')}
  </p>
  <div style="display:flex; flex-wrap:wrap; gap:10px;">
    {pillars.map((p) => <span style={tag}>{p}</span>)}
  </div>
  <div
    style="margin-top:18px; font-family:'IBM Plex Mono','Noto Sans JP',monospace; font-size:13px; color:#8A90A0;"
  >
    <span>{t('up.note')}</span>
  </div>
</div>
