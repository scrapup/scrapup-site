---
import { useTranslations, type Lang } from '../../i18n';
import { REPO } from '../../config';
import LanguageSwitcher from '../LanguageSwitcher.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<div class="top-bar">
  <div class="top-bar__left">
    <div class="item-title top-bar__wordmark">
      scrap<span class="top-bar__accent">up</span>
    </div>
    <div class="kicker top-bar__tagline">
      {t('nav.tagline')}
    </div>
  </div>
  <div class="top-bar__right">
    <LanguageSwitcher lang={lang} />
    <a
      href={REPO}
      target="_blank"
      rel="noopener"
      class="top-bar__link"
    >
      <span class="top-bar__link-label">github.com/scrapup</span>
      <span class="top-bar__arrow">↗</span>
    </a>
  </div>
</div>

<style>
  .top-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
    padding-bottom: 30px;
    border-bottom: 1px solid rgba(var(--hairline), 0.16);
  }

  .top-bar__left {
    display: flex;
    align-items: baseline;
    gap: 14px;
  }

  .top-bar__wordmark {
    font-size: 24px;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .top-bar__accent {
    color: var(--neon);
    text-shadow:
      0 0 16px color-mix(in srgb, var(--neon) 60%, transparent),
      0 0 3px color-mix(in srgb, var(--neon) 50%, transparent);
    animation: scrapupFlicker 7s infinite;
  }

  .top-bar__tagline {
    letter-spacing: 0.08em;
  }

  .top-bar__right {
    display: flex;
    align-items: center;
    gap: 18px;
  }

  .top-bar__link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    color: var(--cy);
    font-family: 'IBM Plex Mono', 'Noto Sans JP', monospace;
    font-size: 12px;
    letter-spacing: 0.04em;
    border-bottom: 1px solid color-mix(in srgb, var(--cy) 35%, transparent);
    padding-bottom: 2px;
  }

  .top-bar__link-label {
    font-weight: 600;
  }

  .top-bar__arrow {
    color: var(--neon);
  }
</style>
