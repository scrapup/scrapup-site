---
import { useTranslations, type Lang } from '../../i18n';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<div class="problem">
  <div class="problem__kicker">
    <span>{t('problem.label')}</span>
  </div>
  <h2 class="section-title problem__title">
    {t('problem.title')}
  </h2>
  <p class="lede problem__lede">
    {t('problem.body')}
  </p>

  <div class="problem__grid">
    <div class="card">
      <div class="problem__stat problem__stat--neon">+37.6%</div>
      <div class="item-desc problem__desc">{t('problem.stat1.desc')}</div>
      <div class="problem__src">arXiv 2506.11022</div>
    </div>
    <div class="card">
      <div class="problem__stat problem__stat--cy">500k+</div>
      <div class="item-desc problem__desc">{t('problem.stat2.desc')}</div>
      <div class="problem__src">arXiv 2508.21634</div>
    </div>
    <div class="card">
      <div class="item-title problem__card-title">{t('problem.card3.title')}</div>
      <div class="item-desc problem__desc">{t('problem.card3.desc')}</div>
      <div class="problem__src">martinfowler.com · ACM TechBrief 2026</div>
    </div>
  </div>
</div>

<style>
  .problem {
    margin-top: 108px;
  }

  .problem__kicker {
    font-family: 'IBM Plex Mono', 'Noto Sans JP', monospace;
    font-size: 11px;
    letter-spacing: 0.2em;
    color: var(--cy);
    margin-bottom: 16px;
  }

  .problem__title {
    margin: 0 0 14px;
    max-width: 20ch;
  }

  .problem__lede {
    margin: 0;
  }

  .problem__grid {
    margin-top: 34px;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(248px, 1fr));
    gap: 18px;
  }

  .problem__stat {
    font-family: 'Space Grotesk', 'Noto Sans JP', sans-serif;
    font-weight: 700;
    font-size: 2.7rem;
    line-height: 1;
  }

  .problem__stat--neon {
    color: var(--neon);
    text-shadow: 0 0 24px color-mix(in srgb, var(--neon) 45%, transparent);
  }

  .problem__stat--cy {
    color: var(--cy);
    text-shadow: 0 0 24px rgba(53, 230, 224, 0.4);
  }

  .problem__desc {
    color: var(--text-muted);
    font-size: 13.5px;
    margin-top: 12px;
  }

  .problem__card-title {
    font-size: 1.15rem;
    line-height: 1.2;
  }

  .problem__src {
    font-family: 'IBM Plex Mono', 'Noto Sans JP', monospace;
    font-size: 11px;
    letter-spacing: 0.04em;
    color: rgba(var(--mark), 0.4);
    margin-top: 14px;
  }
</style>
