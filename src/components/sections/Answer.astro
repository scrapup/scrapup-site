---
import { useTranslations, type Lang } from '../../i18n';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const num =
  "font-family:'IBM Plex Mono','Noto Sans JP',monospace; font-size:12px; color:var(--neon); text-shadow:0 0 10px color-mix(in srgb, var(--neon) 50%, transparent);";
const name =
  "font-family:'Space Grotesk','Noto Sans JP',sans-serif; font-weight:600; font-size:17px; color:#ECEEF4; margin-top:8px;";
const desc = 'font-size:13px; line-height:1.5; color:#8A90A0; margin-top:5px;';
---

<div style="margin-top:108px;">
  <div
    style="font-family:'IBM Plex Mono','Noto Sans JP',monospace; font-size:11px; letter-spacing:.2em; color:var(--cy); margin-bottom:16px;"
  >
    <span>{t('answer.label')}</span>
  </div>
  <h2
    style="margin:0 0 14px; max-width:18ch; font-family:'Space Grotesk','Noto Sans JP',sans-serif; font-weight:600; font-size:clamp(1.7rem,3.2vw,2.6rem); line-height:1.08; letter-spacing:-.02em; color:#F2F3F8;"
  >
    {t('answer.title')}
  </h2>
  <p style="margin:0; max-width:640px; font-size:1.05rem; line-height:1.6; color:#AEB4C2;">
    {t('answer.body')}
  </p>

  <div
    style="margin-top:34px; display:grid; grid-template-columns:repeat(auto-fit,minmax(220px,1fr)); gap:0; border-top:1px solid rgba(120,190,210,.16);"
  >
    <div style="padding:22px 22px 22px 0; border-right:1px solid rgba(120,190,210,.1);">
      <div style={num}>01</div>
      <div style={name}>document</div>
      <div style={desc}>{t('answer.step1.desc')}</div>
    </div>
    <div style="padding:22px; border-right:1px solid rgba(120,190,210,.1);">
      <div style={num}>02</div>
      <div style={name}>validate</div>
      <div style={desc}>{t('answer.step2.desc')}</div>
    </div>
    <div style="padding:22px;">
      <div style={num}>03</div>
      <div style={name}>deliver</div>
      <div style={desc}>{t('answer.step3.desc')}</div>
    </div>
  </div>
</div>
