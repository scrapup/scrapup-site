---
import { useTranslations, type Lang } from '../../i18n';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const shipped = [
  'status.shipped.1',
  'status.shipped.2',
  'status.shipped.3',
  'status.shipped.4',
] as const;
const roadmap = [
  'status.roadmap.1',
  'status.roadmap.2',
  'status.roadmap.3',
  'status.roadmap.4',
] as const;
---

<div style="margin-top:108px;">
  <div
    style="font-family:'IBM Plex Mono','Noto Sans JP',monospace; font-size:11px; letter-spacing:.2em; color:var(--cy); margin-bottom:16px;"
  >
    <span>{t('status.label')}</span>
  </div>
  <h2
    style="margin:0 0 30px; font-family:'Space Grotesk','Noto Sans JP',sans-serif; font-weight:600; font-size:clamp(1.7rem,3.2vw,2.6rem); line-height:1.08; letter-spacing:-.02em; color:#F2F3F8;"
  >
    {t('status.title')}
  </h2>
  <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:18px;">
    <div
      style="background:linear-gradient(180deg, rgba(20,26,40,.55), rgba(14,18,28,.55)); border:1px solid rgba(120,190,210,.16); padding:24px;"
    >
      <div
        style="font-family:'IBM Plex Mono','Noto Sans JP',monospace; font-size:11px; letter-spacing:.16em; color:var(--neon); margin-bottom:14px;"
      >
        <span>{t('status.shipped.label')}</span>
      </div>
      <div style="display:flex; flex-direction:column; gap:10px; font-size:13.5px; color:#C7CCD8;">
        {shipped.map((k) => <div>{t(k)}</div>)}
      </div>
    </div>
    <div
      style="background:linear-gradient(180deg, rgba(16,20,30,.5), rgba(12,15,23,.5)); border:1px dashed rgba(120,190,210,.28); padding:24px;"
    >
      <div
        style="font-family:'IBM Plex Mono','Noto Sans JP',monospace; font-size:11px; letter-spacing:.16em; color:#7E8597; margin-bottom:14px;"
      >
        <span>{t('status.roadmap.label')}</span>
      </div>
      <div style="display:flex; flex-direction:column; gap:10px; font-size:13.5px; color:#8A90A0;">
        {roadmap.map((k) => <div>{t(k)}</div>)}
      </div>
    </div>
  </div>
</div>
