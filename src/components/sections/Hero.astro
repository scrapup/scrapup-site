---
import { useTranslations, type Lang } from '../../i18n';
import { REPO } from '../../config';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<div class="hero">
  <div class="hero__badge">
    <span class="hero__pulse"></span>
    <span>{t('hero.badge')}</span>
  </div>

  <div class="kicker hero__eyebrow">
    <span>{t('hero.eyebrow')}</span>
  </div>

  <h1 class="hero__title">
    {t('hero.headline.pre')}<span class="hero__title-accent"
      >{t('hero.headline.em')}</span
    >{t('hero.headline.post')}
  </h1>

  <p class="hero__lede">
    {t('hero.sub')}
  </p>

  <div class="hero__note">
    <p class="hero__note-text" set:html={t('hero.note.html')} />
  </div>

  <div class="hero__ctas">
    <a href={REPO} target="_blank" rel="noopener" class="btn btn--primary">
      <span>★</span>
      <span>{t('hero.ctaStar')}</span>
    </a>
    <a href={REPO} target="_blank" rel="noopener" class="btn btn--ghost">
      <span>{t('hero.ctaDocs')}</span>
    </a>
  </div>
</div>

<style>
  .hero {
    padding-top: 64px;
  }

  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    padding: 5px 11px;
    border: 1px solid color-mix(in srgb, var(--neon) 60%, transparent);
    background: color-mix(in srgb, var(--neon) 10%, transparent);
    font-family: 'IBM Plex Mono', 'Noto Sans JP', monospace;
    font-size: 11px;
    letter-spacing: 0.16em;
    color: var(--neon);
    margin-bottom: 30px;
    box-shadow:
      0 0 22px color-mix(in srgb, var(--neon) 22%, transparent),
      inset 0 0 14px color-mix(in srgb, var(--neon) 8%, transparent);
  }

  .hero__pulse {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--neon);
    box-shadow:
      0 0 10px color-mix(in srgb, var(--neon) 90%, transparent),
      0 0 0 4px color-mix(in srgb, var(--neon) 20%, transparent);
  }

  .hero__eyebrow {
    font-size: 12px;
    letter-spacing: 0.2em;
    margin-bottom: 22px;
  }

  .hero__title {
    margin: 0;
    max-width: 18ch;
    font-family: 'Space Grotesk', 'Noto Sans JP', sans-serif;
    font-weight: 600;
    font-size: clamp(2.7rem, 5.6vw, 5.1rem);
    line-height: 1.02;
    letter-spacing: -0.025em;
    color: var(--text-strong);
  }

  .hero__title-accent {
    color: var(--neon);
    text-shadow:
      0 0 28px color-mix(in srgb, var(--neon) 55%, transparent),
      0 0 6px color-mix(in srgb, var(--neon) 42%, transparent);
  }

  .hero__lede {
    margin: 26px 0 0;
    max-width: 600px;
    font-size: clamp(1.05rem, 1.5vw, 1.24rem);
    line-height: 1.6;
    color: var(--text-muted);
  }

  .hero__note {
    margin-top: 30px;
    padding-left: 16px;
    border-left: 2px solid var(--neon);
    box-shadow: -1px 0 16px color-mix(in srgb, var(--neon) 20%, transparent);
  }

  .hero__note-text {
    margin: 0;
    max-width: 560px;
    font-size: 0.96rem;
    line-height: 1.55;
    color: var(--text-faint);
  }

  .hero__ctas {
    margin-top: 40px;
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    align-items: center;
  }
</style>
