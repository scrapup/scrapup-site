---
import { AUTHOR } from '../../config';
---

<div
  style="position:relative; background:#07090E; border-top:1px solid rgba(120,190,210,.12); color:#9AA0B0;"
>
  <div
    style="max-width:1180px; margin:0 auto; padding:22px 48px; display:flex; align-items:center; justify-content:space-between; gap:20px; flex-wrap:wrap; font-family:'IBM Plex Mono','Noto Sans JP',monospace; font-size:11.5px; letter-spacing:.04em;"
  >
    <div style="display:flex; align-items:center; gap:18px; flex-wrap:wrap;">
      <span style="color:#ECEEF4; font-weight:600;"
        >scrap<span
          style="color:var(--neon); text-shadow:0 0 12px color-mix(in srgb, var(--neon) 55%, transparent);"
          >up</span
        ></span
      >
      <span style="color:#5A6172;">MIT © 2026</span>
      <span style="color:#5A6172;">scrapup.dev</span>
    </div>
    <div style="color:#5A6172;">{AUTHOR}</div>
  </div>
</div>
