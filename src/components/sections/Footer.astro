---
import { AUTHOR } from '../../config';
---

<div class="footer">
  <div class="footer__inner">
    <div class="footer__left">
      <span class="footer__wordmark"
        >scrap<span class="footer__wordmark-up">up</span></span
      >
      <span class="footer__meta">MIT © 2026</span>
      <span class="footer__meta">scrapup.dev</span>
    </div>
    <div class="footer__author">{AUTHOR}</div>
  </div>
</div>

<style>
  .footer {
    position: relative;
    background: var(--ink-deep);
    border-top: 1px solid rgba(var(--hairline), 0.12);
    color: var(--text-footer);
  }

  .footer__inner {
    max-width: 1180px;
    margin: 0 auto;
    padding: 22px 48px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    flex-wrap: wrap;
    font-family: 'IBM Plex Mono', 'Noto Sans JP', monospace;
    font-size: 11.5px;
    letter-spacing: 0.04em;
  }

  .footer__left {
    display: flex;
    align-items: center;
    gap: 18px;
    flex-wrap: wrap;
  }

  .footer__wordmark {
    color: var(--light-ink);
    font-weight: 600;
  }

  .footer__wordmark-up {
    color: var(--neon);
    text-shadow: 0 0 12px color-mix(in srgb, var(--neon) 55%, transparent);
  }

  .footer__meta {
    color: var(--text-quiet);
  }

  .footer__author {
    color: var(--text-quiet);
  }
</style>
